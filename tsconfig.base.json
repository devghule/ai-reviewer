{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "baseUrl": ".",
    "paths": {
      "@repo/shared/*": ["packages/shared/*"],
      "@repo/schemas/*": ["packages/schemas/*"],
      "@repo/git-engine/*": ["packages/git-engine/*"],
      "@repo/ai-engine/*": ["packages/ai-engine/*"],
      "@repo/review-engine/*": ["packages/review-engine/*"],
      "@repo/config/*": ["packages/config/*"]
    }
  }
}